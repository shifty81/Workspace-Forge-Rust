# Default: LF everywhere
* text=auto eol=lf

# Windows scripts keep CRLF
*.bat text eol=crlf
*.cmd text eol=crlf

# Binary assets — no line-ending conversion, no diff
*.png  binary
*.jpg  binary
*.jpeg binary
*.gif  binary
*.ico  binary
*.ttf  binary
*.otf  binary
*.woff binary
*.woff2 binary
*.wav  binary
*.ogg  binary
*.mp3  binary
*.flac binary
*.ron  text eol=lf
*.toml text eol=lf
*.rs   text eol=lf
*.sh   text eol=lf
*.md   text eol=lf
